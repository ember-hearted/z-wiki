#!/usr/bin/env bash
set -euo pipefail

# z-wiki pre-commit hook
# 对 staged 的 TS/JS 文件做 format + lint
# 通不过则阻止提交，让开发者在 CI 之前先发现问题。

staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|mjs|mts)$' || true)

if [[ -z "$staged" ]]; then
  exit 0
fi

echo "🔍 pre-commit: biome check — $(echo "$staged" | wc -l | tr -d ' ') file(s)"

echo "$staged" | xargs npx --no-install biome check --write --no-errors-on-unmatched

echo "$staged" | xargs git add
