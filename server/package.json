{
  "name": "@z-wiki/server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./uploadExts": {
      "types": "./src/uploadExts.ts",
      "node": "./dist/uploadExts.js",
      "default": "./src/uploadExts.ts"
    },
    "./markdown": {
      "types": "./src/markdown.ts",
      "node": "./dist/markdown.js",
      "default": "./src/markdown.ts"
    },
    "./ingestProgress": {
      "types": "./src/ingestProgress.ts",
      "default": "./src/ingestProgress.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.2.0",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0"
  }
}
